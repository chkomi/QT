# 업비트 API 키 (https://upbit.com/mypage/open_api_management)
UPBIT_ACCESS_KEY=여기에_액세스_키_입력
UPBIT_SECRET_KEY=여기에_시크릿_키_입력

# 빗썸 API 키 (https://www.bithumb.com/u1/US138)
BITHUMB_CON_KEY=여기에_Connect_Key_입력
BITHUMB_SEC_KEY=여기에_Secret_Key_입력

# OKX API 키 (https://www.okx.com/account/my-api)
OKX_API_KEY=여기에_API_Key_입력
OKX_SECRET_KEY=여기에_Secret_Key_입력
OKX_PASSPHRASE=여기에_Passphrase_입력

# 텔레그램 봇 (선택사항)
TELEGRAM_TOKEN=여기에_봇_토큰_입력
TELEGRAM_CHAT_ID=여기에_채팅_ID_입력
